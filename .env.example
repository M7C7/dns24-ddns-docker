# ============================================================================
#  DDNS Updater for dns24.ch — Configuration
#  
#  Copy this file to config/.env and edit your settings.
#  Passwords with special chars ($, #, !, @) MUST use single quotes.
# ============================================================================

# ── Credentials (required) ─────────────────────────────────────────────────
DNS24_USER='your-email@example.com'
DNS24_PASS='your-password-here'

# ── Discord Notifications (optional) ───────────────────────────────────────
# Leave empty to disable. Updates still work, just silently.
DISCORD_WEBHOOK=''

# Separate channel for propagation tracking (defaults to main if empty)
DISCORD_WEBHOOK_PROPAGATION=''

# Notify when IP hasn't changed (noisy — default: false)
DISCORD_NOTIFY_UNCHANGED='false'

# Notify on container start (default: true)
DISCORD_NOTIFY_STARTUP='true'

# ── Timing ─────────────────────────────────────────────────────────────────
# How often to check for IP changes (seconds)
CHECK_INTERVAL='30'

# Timeout for public IP resolvers (seconds)
RESOLVER_TIMEOUT='5'

# Timeout for dns24 API calls (seconds)
DNS24_TIMEOUT='10'

# ── IP Resolution ──────────────────────────────────────────────────────────
# Your own IP resolver (e.g. https://myresolver.example.com/ip)
# Leave empty to use public resolvers only
SELF_HOSTED_RESOLVER=''

# Force IPv4 for curl (recommended unless you have IPv6-only setup)
FORCE_IPV4='true'

# Public resolvers (comma-separated, tried in order)
PUBLIC_RESOLVERS='https://ifconfig.me,https://icanhazip.com,https://api.ipify.org,https://checkip.amazonaws.com'

# ── NS Verification ───────────────────────────────────────────────────────
# dns24.ch authoritative nameservers (used to verify updates landed)
NS1='ns1.dns24.ch'
NS2='ns2.dns24.ch'

# ── Drift Detection ───────────────────────────────────────────────────────
# Check a random record against NS every N cycles to detect silent changes
# Example: 10 means every 10th cycle (at 30s interval = every 5 minutes)
DRIFT_CHECK_INTERVAL='10'

# ── DNS Propagation Tracking ──────────────────────────────────────────────
# Track how fast changes appear on global DNS resolvers
PROPAGATION_ENABLED='true'

# Seconds between propagation check rounds
PROPAGATION_INTERVAL='30'

# Max rounds before giving up
PROPAGATION_MAX_ROUNDS='10'

# DNS zones to check (format: label|type|ip, comma-separated)
# Anycast resolvers test independent cache pools.
# Anycast resolvers test independent cache pools.
PROPAGATION_ZONES="Cloudflare|Anycast|1.1.1.1,Google DNS|Anycast|8.8.8.8,OpenDNS|Anycast|208.67.222.222"

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL='info'
KEEP_IP_HISTORY='true'
IP_HISTORY_MAX_LINES='1000'

# ── API (advanced) ─────────────────────────────────────────────────────────
DNS24_API_URL='http://dyn.dns24.ch/update'
